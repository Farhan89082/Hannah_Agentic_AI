# ─────────────────────────────────────────────
#  Hannah – AI Research Assistant
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env to GitHub.
# ─────────────────────────────────────────────

# Google Gemini – LLM and TTS (free tier, no card needed)
# Get yours at: https://aistudio.google.com → Get API key
GOOGLE_API_KEY=your_google_api_key_here

# Deepgram – Speech-to-Text (free tier, $200 credit, no card needed)
# Get yours at: https://console.deepgram.com/signup
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# FDA Open Data API (optional but recommended for higher rate limits)
# Register free at: https://open.fda.gov/apis/authentication/
FDA_API_KEY=your_fda_api_key_here

# LiveKit – Voice agent infrastructure
# Get yours at: https://cloud.livekit.io
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_URL=wss://your-project.livekit.cloud
